{
  "version": 1,
  "hooks": {
    "Stop": [
      {
        "type": "command",
        "bash": "${CLAUDE_PLUGIN_ROOT}/hooks/check-observation-log.sh",
        "powershell": "echo 'check-observation-log: bash-only gate (skipped on Windows)'",
        "timeoutSec": 30
      },
      {
        "type": "command",
        "bash": "${CLAUDE_PLUGIN_ROOT}/hooks/memory-deterministic-block.sh",
        "powershell": "& \"${CLAUDE_PLUGIN_ROOT}\\hooks\\run.ps1\" deterministic_block.py",
        "timeoutSec": 15
      },
      {
        "type": "command",
        "bash": "${CLAUDE_PLUGIN_ROOT}/hooks/memory-verify-compliance.sh",
        "powershell": "& \"${CLAUDE_PLUGIN_ROOT}\\hooks\\run.ps1\" verify_compliance.py",
        "timeoutSec": 15
      },
      {
        "type": "command",
        "bash": "${CLAUDE_PLUGIN_ROOT}/hooks/memory-shadow-judge.sh",
        "powershell": "& \"${CLAUDE_PLUGIN_ROOT}\\hooks\\run.ps1\" verify_retry_shadow.py",
        "timeoutSec": 30
      },
      {
        "type": "command",
        "bash": "${CLAUDE_PLUGIN_ROOT}/hooks/memory-pending-promote.sh",
        "powershell": "& \"${CLAUDE_PLUGIN_ROOT}\\hooks\\run.ps1\" pending_queue_manager.py promote",
        "timeoutSec": 10
      }
    ],
    "SessionStart": [
      {
        "type": "command",
        "bash": "${CLAUDE_PLUGIN_ROOT}/hooks/session-start-inject.sh",
        "powershell": "& \"${CLAUDE_PLUGIN_ROOT}\\hooks\\run.ps1\" session_start_inject.py",
        "timeoutSec": 15
      }
    ]
  }
}
