{
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          { "type": "command", "command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/userpromptsubmit-retrieve-inject.sh\"", "timeout": 30 },
          { "type": "command", "command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/userpromptsubmit-pending-inject.sh\"", "timeout": 10 },
          { "type": "command", "command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/userpromptsubmit-shadow-alert-inject.sh\"", "timeout": 10 }
        ]
      }
    ],
    "PostToolUse": [
      {
        "hooks": [
          { "type": "command", "command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/posttooluse-deterministic-block.sh\"", "timeout": 15 }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          { "type": "command", "command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/sessionstart-init.sh\"", "timeout": 10 }
        ]
      }
    ]
  }
}
