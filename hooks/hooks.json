{
  "hooks": {
    "Stop": [
      {
        "hooks": [
          { "type": "command", "command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/check-observation-log.sh\"", "timeout": 10 },
          { "type": "command", "command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/memory-deterministic-block.sh\"", "timeout": 10 },
          { "type": "command", "command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/memory-verify-compliance.sh\"", "timeout": 5 },
          { "type": "command", "command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/memory-shadow-judge.sh\"", "timeout": 30 },
          { "type": "command", "command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/memory-pending-promote.sh\"", "timeout": 5 }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          { "type": "command", "command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/memory-retrieve-inject.sh\"", "timeout": 15 },
          { "type": "command", "command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/memory-pending-inject.sh\"", "timeout": 5 },
          { "type": "command", "command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/memory-shadow-alert-inject.sh\"", "timeout": 5 }
        ]
      }
    ]
  }
}
